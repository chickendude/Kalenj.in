{
	"name": "kalenjin-app",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"lint": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"prepare": "svelte-kit sync || echo ''",
		"db:generate": "prisma generate",
		"db:migrate": "prisma migrate dev",
		"db:deploy": "prisma migrate deploy",
		"postdb:deploy": "npm run backfill:observed-forms",
		"db:studio": "prisma studio",
		"backfill:observed-forms": "tsx scripts/backfill-observed-word-forms.ts",
		"create-admin": "tsx scripts/create-admin.ts",
		"check": "npm run lint",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.3.3",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/pg": "^8.16.0",
		"@vitest/coverage-v8": "^4.1.4",
		"dotenv": "^17.3.1",
		"prisma": "^7.4.0",
		"svelte": "^5.49.2",
		"svelte-check": "^4.3.6",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.1.4"
	},
	"dependencies": {
		"@prisma/adapter-pg": "^7.4.0",
		"@prisma/client": "^7.4.0",
		"argon2": "^0.44.0",
		"ffmpeg-static": "^5.3.0",
		"pg": "^8.18.0"
	}
}
