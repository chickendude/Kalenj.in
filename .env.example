# Required: Postgres connection string used by Prisma and the app server.
# Replace the username and password placeholders with your own values.
DATABASE_URL="postgresql://kalenjin_user:your_password@localhost:5432/kalenjin_app?schema=public"

# Optional: Node server port for local preview or VPS runtime.
PORT=3000

# Optional but recommended in production: public origin of the deployed app.
ORIGIN="http://localhost:3000"
