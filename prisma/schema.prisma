// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum PartOfSpeech {
  NOUN
  VERB
  ADJECTIVE
  ADVERB
  PRONOUN
  PREPOSITION
  CONJUNCTION
  INTERJECTION
  PHRASE
  OTHER
}

enum CefrLevel {
  A1
  A2
  B1
  B2
  C1
}

enum PublishStatus {
  DRAFT
  PUBLISHED
}

enum CourseLessonType {
  VOCABULARY
  STORY
}

enum VocabularyLessonType {
  GRAMMAR
  VOCAB
  EXPRESSION
}

model Word {
  id           String           @id @default(cuid())
  kalenjin     String
  translations String
  kalenjinNormalized String
  partOfSpeech PartOfSpeech?
  notes        String?
  pluralForm   String?
  pluralFormNormalized String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  sentences    WordSentence[]
  tokenLinks   ExampleSentenceToken[]
  storyTokenLinks StorySentenceToken[]
  tokenSegments ExampleSentenceTokenSegment[]
  storyTokenSegments StorySentenceTokenSegment[]
  lessonWords  LessonWord[]
  spellings    WordSpelling[]

  @@index([kalenjin])
  @@index([kalenjinNormalized])
  @@index([pluralFormNormalized])
  @@index([translations])
}

model WordSpelling {
  id                 String   @id @default(cuid())
  wordId             String
  spelling           String
  spellingNormalized String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  word               Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([wordId, spellingNormalized])
  @@index([spellingNormalized])
}

model ExampleSentence {
  id          String               @id @default(cuid())
  kalenjin    String
  english     String
  source      String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  words       WordSentence[]
  tokens      ExampleSentenceToken[]
  lessonWords LessonWord[]

  @@index([kalenjin])
}

model ExampleSentenceToken {
  id                String          @id @default(cuid())
  exampleSentenceId String
  wordId            String?
  inContextTranslation String?
  tokenOrder        Int
  surfaceForm       String
  normalizedForm    String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  exampleSentence   ExampleSentence @relation(fields: [exampleSentenceId], references: [id], onDelete: Cascade)
  word              Word?           @relation(fields: [wordId], references: [id], onDelete: SetNull)
  segments          ExampleSentenceTokenSegment[]

  @@unique([exampleSentenceId, tokenOrder])
  @@index([exampleSentenceId])
  @@index([wordId])
  @@index([normalizedForm])
}

model ExampleSentenceTokenSegment {
  id            String               @id @default(cuid())
  tokenId       String
  wordId        String?
  segmentOrder  Int
  segmentStart  Int
  segmentEnd    Int
  surfaceForm   String
  normalizedForm String
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  token         ExampleSentenceToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  word          Word?                @relation(fields: [wordId], references: [id], onDelete: SetNull)

  @@unique([tokenId, segmentOrder])
  @@index([tokenId])
  @@index([wordId])
  @@index([normalizedForm])
}

model WordSentence {
  wordId            String
  exampleSentenceId String
  word              Word            @relation(fields: [wordId], references: [id], onDelete: Cascade)
  exampleSentence   ExampleSentence @relation(fields: [exampleSentenceId], references: [id], onDelete: Cascade)

  @@id([wordId, exampleSentenceId])
  @@index([exampleSentenceId])
}

model Story {
  id          String          @id @default(cuid())
  title       String
  description String?
  source      String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  sentences   StorySentence[]
  lesson      Lesson?
}

model StorySentence {
  id            String   @id @default(cuid())
  storyId       String
  sentenceOrder Int
  speaker       String?
  kalenjin      String
  english       String
  grammarNotes  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  story         Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  tokens        StorySentenceToken[]

  @@unique([storyId, sentenceOrder])
  @@index([storyId])
  @@index([kalenjin])
}

model StorySentenceToken {
  id                  String        @id @default(cuid())
  storySentenceId     String
  wordId              String?
  inContextTranslation String?
  tokenOrder          Int
  surfaceForm         String
  normalizedForm      String
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  storySentence       StorySentence @relation(fields: [storySentenceId], references: [id], onDelete: Cascade)
  word                Word?         @relation(fields: [wordId], references: [id], onDelete: SetNull)
  segments            StorySentenceTokenSegment[]

  @@unique([storySentenceId, tokenOrder])
  @@index([storySentenceId])
  @@index([wordId])
  @@index([normalizedForm])
}

model StorySentenceTokenSegment {
  id            String             @id @default(cuid())
  tokenId       String
  wordId        String?
  segmentOrder  Int
  segmentStart  Int
  segmentEnd    Int
  surfaceForm   String
  normalizedForm String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  token         StorySentenceToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  word          Word?              @relation(fields: [wordId], references: [id], onDelete: SetNull)

  @@unique([tokenId, segmentOrder])
  @@index([tokenId])
  @@index([wordId])
  @@index([normalizedForm])
}

model CefrEnglishTarget {
  id                    String       @id @default(cuid())
  level                 CefrLevel
  english               String       @unique
  notes                 String?
  coveredByLessonWordId String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  coveredByLessonWord   LessonWord?  @relation(fields: [coveredByLessonWordId], references: [id], onDelete: SetNull)

  @@index([level])
  @@index([coveredByLessonWordId])
}

model Lesson {
  id              String                @id @default(cuid())
  level           CefrLevel
  title           String
  lessonOrder     Int
  type            CourseLessonType
  vocabularyType  VocabularyLessonType?
  grammarMarkdown String?
  notes           String?
  status          PublishStatus         @default(DRAFT)
  storyId         String?               @unique
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  sections        LessonSection[]
  story           Story?                @relation(fields: [storyId], references: [id], onDelete: SetNull)

  @@unique([level, lessonOrder])
  @@index([level])
  @@index([type])
}

model LessonSection {
  id        String           @id @default(cuid())
  lessonId  String
  title     String?
  sectionOrder Int
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  lesson    Lesson           @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  words     LessonWord[]

  @@unique([lessonId, sectionOrder])
  @@index([lessonId])
}

model LessonWord {
  id                     String          @id @default(cuid())
  lessonSectionId        String
  wordId                 String?
  kalenjin               String
  translations           String
  itemOrder              Int
  sentenceId             String
  sentenceTranslation    String?
  wordForWordTranslation String?
  notesMarkdown          String?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  lessonSection          LessonSection   @relation(fields: [lessonSectionId], references: [id], onDelete: Cascade)
  word                   Word?           @relation(fields: [wordId], references: [id], onDelete: SetNull)
  sentence               ExampleSentence @relation(fields: [sentenceId], references: [id], onDelete: Restrict)
  coveredCefrTargets     CefrEnglishTarget[]

  @@unique([lessonSectionId, itemOrder])
  @@unique([lessonSectionId, wordId])
  @@index([lessonSectionId])
  @@index([wordId])
  @@index([sentenceId])
}
